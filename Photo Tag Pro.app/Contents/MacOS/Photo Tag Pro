#!/bin/bash
# Move to the project root directory relative to the app bundle location
cd "$(dirname "$0")/../../.."

# Redirect stdout and stderr to a log file for troubleshooting
exec > app_startup.log 2>&1

echo "=== Starting Photo Tag Pro ==="
echo "Date: $(date)"
echo "Current directory: $(pwd)"

# Set PATH to include standard Node and npm paths on macOS
export PATH="/usr/local/bin:/opt/homebrew/bin:/usr/bin:/bin:/usr/sbin:/sbin:$PATH"

# Check if node is installed
if ! command -v node &> /dev/null; then
  echo "Error: Node.js is not installed or not in PATH."
  echo "PATH is: $PATH"
  osascript -e 'display alert "Photo Tag Pro Error" message "Node.js non è installato o non è stato trovato. Per favore installa Node.js per avviare l'\''applicazione."'
  exit 1
fi

# First check if backend dependencies are installed, if not install them
if [ ! -d "backend/node_modules" ]; then
  echo "Installing backend dependencies..."
  npm install --prefix backend
fi



# Kill any existing server running on 3001 using native tools
echo "Checking port 3001..."
PORT_PID=$(lsof -t -i :3001)
if [ ! -z "$PORT_PID" ]; then
  echo "Killing existing process on port 3001 (PID: $PORT_PID)..."
  kill -9 $PORT_PID
  # Give the OS time to release the port
  sleep 1
fi

# Start the node server in background using robust nohup and absolute node path
echo "Starting backend server..."
NODE_BIN=$(command -v node)
nohup "$NODE_BIN" backend/server.js > backend_server.log 2>&1 &

# Wait 2 seconds for the server to spin up
sleep 2

# Open default browser
echo "Opening browser at http://localhost:3001..."
open http://localhost:3001

# Exit immediately
exit 0
